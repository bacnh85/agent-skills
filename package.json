{
  "name": "@bacnh85/agent-skills",
  "version": "0.1.0",
  "description": "Promote installed agent skills into a categorized central repository.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "agent-skills": "./dist/src/cli.js"
  },
  "files": ["dist", "skills"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
