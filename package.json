{
  "name": "@bacnh85/agent-skills",
  "version": "0.1.0",
  "description": "Manage repository-based AI agent skills from git and local sources.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "agent-skills": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/src/cli.js',0o755)\"",
    "install": "node -e \"const fs=require('node:fs'),r=process.env.npm_package_resolved||'',m=r.match(/github\\.com[:/]([^/]+)\\/([^/#]+?)(?:\\.git)?#([0-9a-f]+)/i)||[],s=m[1]?'https://codeload.github.com/'+m[1]+'/'+m[2].replace(/\\.git$/,'')+'/tar.gz/'+m[3]:'https://codeload.github.com/bacnh85/agent-skills/tar.gz/refs/heads/main';if(fs.existsSync('dist/src/cli.js'))process.exit(0);const t=Buffer.from('','base64').toString().replace('__SPEC__',JSON.stringify(s));fs.mkdirSync('dist/src',{recursive:true});fs.writeFileSync('dist/src/cli.js',t);fs.chmodSync('dist/src/cli.js',0o755);process.exit(0)\"",
    "prepare": "node scripts/prepare-package.cjs",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  }
}
